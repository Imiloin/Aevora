---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
import FormattedDate from '@components/FormattedDate.astro';
import { slugify } from '@utils/slug';
import { getSortedPosts } from '@utils/posts';
import { Image } from 'astro:assets';

import blogConfig from '@configs/blog.json';

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  const seriesMap = new Map();

  // fetch all series and map them to slugs
  posts.forEach((post) => {
    if (post.data.series) {
      post.data.series.forEach((name) => {
        const slug = slugify(name);
        seriesMap.set(slug, name);
      });
    }
  });

  return Array.from(seriesMap.entries()).map(([slug, name]) => ({
    params: { series: slug },
    props: { name },
  }));
}

const { series } = Astro.params as { series: string };
const { name } = Astro.props as { name: string };

// fetch all posts in the series (chronological order for series)
const allPosts = await getSortedPosts();
const posts = allPosts
  .filter((post) => post.data.series?.some((s) => slugify(s) === series))
  .reverse(); // reverse to chronological order for series

const title = `${name} - Series`;
const description = `Articles in series: ${name}`;
const width = blogConfig.general.width;
const { width: seriesImgWidth, height: seriesImgHeight } = blogConfig.seriesImage;
---

<BaseLayout title={title} description={description} lang="zh" footerWidth={width}>
  <style define:vars={{ width }}>
    main {
      width: var(--width);
    }
    .post-card :global(.post-card-arrow) {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--gray-800);
    }
    @media (max-width: 768px) {
      main {
        font-size: 0.9rem;
      }
      .post-card :global(.post-card-arrow) {
        display: none;
      }
    }
  </style>

  <main class="flex flex-col justify-center">
    <h1 class="my-8 w-full text-center">Series: {name}</h1>
    {
      posts.map((post, index) => (
        <a
          href={`/blog/${post.id}/`}
          class:list={[
            'post-card relative flex w-[calc(100%-4rem)] items-center overflow-hidden border-b border-[var(--gray-300)] py-4 pr-16 pl-0 text-inherit no-underline hover:bg-[var(--gray-200)] hover:shadow-none max-md:w-full max-md:flex-col max-md:pr-0',
            index === 0 && 'border-t border-[var(--gray-300)]',
          ]}
        >
          <Image
            width={seriesImgWidth}
            height={seriesImgHeight}
            src={post.data.heroImage}
            alt={post.data.title}
            class="my-0 mr-8 ml-4 h-auto w-[160px] rounded max-md:mx-8 max-md:my-4 max-md:w-[calc(100%-2rem)] max-md:rounded-lg"
          />
          <div class="flex-1 max-md:w-[calc(100%-2rem)] max-md:text-left">
            <h2 class="my-2 text-[1.2em] leading-normal">{post.data.title}</h2>
            <p class="text-sm text-[var(--gray-700)]">
              <FormattedDate date={post.data.pubDate} />
            </p>
            <p class="mt-2 text-base text-[var(--text)]">{post.data.description}</p>
          </div>
          <ArrowUpRight class="post-card-arrow" />
        </a>
      ))
    }
  </main>
</BaseLayout>
