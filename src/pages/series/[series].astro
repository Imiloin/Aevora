---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArrowIcon from '@components/icons/ArrowIcon.astro';
import FormattedDate from '@components/FormattedDate.astro';
import { slugify } from '@utils/slug';
import { getSortedPosts } from '@utils/posts';
import { Image } from 'astro:assets';

import blogConfig from '@configs/blog.json';

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  const seriesMap = new Map();

  // fetch all series and map them to slugs
  posts.forEach((post) => {
    if (post.data.series) {
      post.data.series.forEach((name) => {
        const slug = slugify(name);
        seriesMap.set(slug, name);
      });
    }
  });

  return Array.from(seriesMap.entries()).map(([slug, name]) => ({
    params: { series: slug },
    props: { name },
  }));
}

const { series } = Astro.params as { series: string };
const { name } = Astro.props as { name: string };

// fetch all posts in the series (chronological order for series)
const allPosts = await getSortedPosts();
const posts = allPosts
  .filter((post) => post.data.series?.some((s) => slugify(s) === series))
  .reverse(); // reverse to chronological order for series

const title = `${name} - Series`;
const description = `Articles in series: ${name}`;
const width = blogConfig.general.width;
const { width: seriesImgWidth, height: seriesImgHeight } = blogConfig.seriesImage;
---

<BaseLayout title={title} description={description} lang="zh" footerWidth={width}>
  <style define:vars={{ width }}>
    main {
      width: var(--width);
      display: flex;
      flex-direction: column; /* Change to column layout */
      justify-content: center;
    }
    .series-title {
      text-align: center;
      margin: 2rem 0;
      width: 100%;
    }
    .post-card {
      width: calc(100% - 4rem); /* Adjust width */
      border-bottom: 1px solid var(--gray-300); /* Add bottom border to separate cards */
      overflow: hidden;
      text-decoration: none; /* Ensure links have no underline */
      color: inherit; /* Ensure text color is inherited */
      display: flex; /* Flex layout for card */
      align-items: center;
      padding: 1rem 4rem 1rem 0; /* Add padding for spacing */
      position: relative; /* For positioning the arrow */

      &:hover {
        box-shadow: none;
        background-color: var(--gray-200);
      }
    }
    .post-card.first-card {
      border-top: 1px solid var(--gray-300); /* Add top border to first card */
    }
    .post-card img {
      width: 160px; /* Fixed width for image */
      height: auto;
      border-radius: 4px;
      margin: 0 2rem 0 1rem; /* Add margin for spacing */
    }
    .post-card-content {
      flex: 1; /* Allow content to take remaining space */
    }
    .post-card-title {
      font-size: 1.2em;
      margin: 0.5rem 0;
    }
    .post-card-date {
      font-size: 0.875em;
      color: var(--gray-700);
    }
    .post-card-description {
      font-size: 1em;
      color: var(--text);
      margin-top: 0.5rem;
    }
    .post-card :global(.post-card-arrow) {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--gray-800);
    }
    @media (max-width: 720px) {
      main {
        font-size: 0.9rem; /* Adjust font size for small screens */
      }
      .post-card {
        width: 100%;
        flex-direction: column; /* Stack image and content vertically on small screens */
        padding-right: 0; /* Adjust padding for small screens */
      }
      .post-card img {
        width: calc(100% - 2rem);
        border-radius: 8px;
        margin: 1rem 2rem;
      }
      .post-card-content {
        text-align: left; /* Ensure text is left-aligned on small screens */
        width: calc(100% - 2rem);
      }
      .post-card :global(.post-card-arrow) {
        display: none; /* Hide arrow on small screens */
      }
    }
  </style>

  <main>
    <h1 class="series-title">Series: {name}</h1>
    {
      posts.map((post, index) => (
        <a href={`/blog/${post.id}/`} class={`post-card ${index === 0 ? 'first-card' : ''}`}>
          <Image
            width={seriesImgWidth}
            height={seriesImgHeight}
            src={post.data.heroImage}
            alt={post.data.title}
          />
          <div class="post-card-content">
            <h2 class="post-card-title">{post.data.title}</h2>
            <p class="post-card-date">
              <FormattedDate date={post.data.pubDate} />
            </p>
            <p class="post-card-description">{post.data.description}</p>
          </div>
          <ArrowIcon class="post-card-arrow" />
        </a>
      ))
    }
  </main>
</BaseLayout>
