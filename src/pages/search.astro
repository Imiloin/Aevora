---
import BaseLayout from '@layouts/BaseLayout.astro';
import SearchBar from '@components/SearchBar.astro';

const title = 'Search';
const description = 'Search for posts on this site.';
---

<BaseLayout title={title} description={description}>
  <style>
    body {
      display: flex;
      flex-direction: column;
      min-height: calc(100vh - 4em);
    }
    main {
      /* flex: 1 makes the main element take up the remaining space */
      flex: 1;
    }
    html {
      scrollbar-gutter: stable; /* Prevent page jitter when scrollbar disappears */
      overflow-y: scroll; /* Always show scrollbar */
    }
    .search-bar {
      width: var(--width);
      max-width: calc(100% - 2em);
      margin: 2em auto;
    }
  </style>

  <main>
    <div class="search-bar">
      <SearchBar />
    </div>
  </main>
</BaseLayout>
