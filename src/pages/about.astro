---
import BaseLayout from '@layouts/BaseLayout.astro';
import Envelope from '@components/icons/Envelope.astro';

import '@styles/email-button.css';

import aboutConfig from '@configs/about.json';

const title = 'About';
const description = `Learn more about ${aboutConfig.basic.name}.`;

const { basic, links } = aboutConfig;
---

<BaseLayout title={title} description={description} footerWidth="900px">
  <style>
    body {
      display: flex;
      flex-direction: column;
      min-height: calc(100vh - 4em);
    }
    .email-button :global(svg) {
      margin-left: 10px;
    }
  </style>

  <main class="flex flex-1 flex-col items-center justify-center">
    <div
      class="contact-section w-[var(--width)] max-w-[calc(100vw-100px-8em)] rounded-[50px] bg-[var(--gray-825)] p-[50px] text-center text-white max-[720px]:max-w-[calc(100%-4em)] max-[720px]:rounded-[40px] max-[720px]:p-5"
    >
      <h1 class="text-[2.5em] text-white">{basic.bio}</h1>
      <p class="text-[1.2em] max-[636px]:text-base">{basic.name} &nbsp; | &nbsp; {basic.status}</p>
      <a
        href={`mailto:${basic.email}`}
        class="email-button button my-4 inline-flex items-center rounded-[10px] border-none bg-white px-5 py-2.5 text-[var(--gray-850)] no-underline"
        >Email Me <Envelope /></a
      >
      <nav>
        <ul class="list-none p-0">
          <li class="mx-[15px] inline"><a class="text-white no-underline" href="/">Home</a></li>
          <li class="mx-[15px] inline">
            <a class="text-white no-underline" href={links.resume}>Resume</a>
          </li>
          <li class="mx-[15px] inline">
            <a class="text-white no-underline" href={links.github}>GitHub</a>
          </li>
        </ul>
      </nav>
    </div>
  </main>
</BaseLayout>
