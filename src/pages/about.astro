---
import BaseLayout from '@layouts/BaseLayout.astro';
import EnvelopeIcon from '@components/icons/EnvelopeIcon.astro';

import '@styles/email-button.scss';

import aboutConfig from '@configs/about.json';

const title = 'About';
const description = `Learn more about ${aboutConfig.basic.name}.`;

const { basic, links } = aboutConfig;
---

<BaseLayout title={title} description={description} footerWidth="900px">
  <style>
    body {
      display: flex;
      flex-direction: column;
      min-height: calc(100vh - 4em);
    }
    main {
      display: flex;
      /* flex: 1 makes the main element take up the remaining space */
      flex: 1;
      align-items: center;
      justify-content: center;
      flex-direction: column;
    }

    .contact-section {
      background-color: var(--gray-825);
      width: var(--width);
      max-width: calc(100vw - 100px - 8em);
      color: var(--white);
      text-align: center;
      padding: 50px;
      border-radius: 50px;
    }

    .contact-section h1 {
      color: var(--white);
      font-size: 2.5em;
    }

    .contact-section p {
      font-size: 1.2em;
    }

    .email-button {
      background-color: var(--white);
      color: var(--gray-850);
      padding: 10px 20px;
      border: none;
      border-radius: 10px;
      text-decoration: none;
      margin: 1em 0;
      display: inline-flex;
      align-items: center;
    }
    .email-button :global(svg) {
      margin-left: 10px;
    }

    nav ul {
      list-style: none;
      padding: 0;
    }

    nav ul li {
      display: inline;
      margin: 0 15px;
    }

    nav ul li a {
      color: var(--white);
      text-decoration: none;
    }

    @media (max-width: 720px) {
      .contact-section {
        max-width: calc(100% - 4em);
        padding: 20px;
        border-radius: 40px;
      }
    }
    @media (max-width: 636px) {
      .contact-section p {
        font-size: 1em;
      }
    }
  </style>

  <main>
    <div class="contact-section">
      <h1>{basic.bio}</h1>
      <p>{basic.name} &nbsp; | &nbsp; {basic.status}</p>
      <a href={`mailto:${basic.email}`} class="email-button button">Email Me <EnvelopeIcon /></a>
      <nav>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href={links.resume}>Resume</a></li>
          <li>
            <a href={links.github}>GitHub</a>
          </li>
        </ul>
      </nav>
    </div>
  </main>
</BaseLayout>
