---
import type { CollectionEntry } from 'astro:content';
import PostCard from '@components/PostCard.astro';
import ChevronLeft from '@components/icons/ChevronLeft.astro';
import ChevronRight from '@components/icons/ChevronRight.astro';
import { paginatePosts, buildPageList } from '@utils/pagination';

interface Props {
  posts: CollectionEntry<'blog'>[];
  currentPage?: number;
  totalPages?: number;
}

const { posts, currentPage = 1, totalPages = 1 } = Astro.props;

const paginatedPosts = paginatePosts(posts, currentPage);
const pageList = buildPageList(currentPage, totalPages);

const indexPageLink = currentPage === 2;
const hasPrevPage = currentPage > 1;
const hasNextPage = totalPages > currentPage;
---

<style>
  .arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.25em;
    padding: 0.375em 0.5em;
    color: var(--text);

    &.inactive {
      color: var(--gray-400);
    }

    &.active:hover {
      background-color: var(--gray-400);
    }
  }

  .index {
    border-radius: 0.25em;
    padding: 0.5em 1em;
    text-decoration: none;

    &.index-dots {
      cursor: default;
    }

    &.index-current {
      background-color: var(--gray-850);
      color: var(--white);
    }

    &.index-other {
      color: var(--text);

      &:hover {
        background-color: var(--gray-400);
      }
    }
  }
</style>

<section>
  <ul class="m-0 flex list-none flex-wrap gap-8 p-0 max-md:gap-2">
    {
      paginatedPosts.map((post, index) => (
        <PostCard post={post} isFirstChild={currentPage === 1 && index === 0} />
      ))
    }
  </ul>
  {
    totalPages > 1 && (
      <nav aria-label="Pagination" class="mt-8 flex items-center justify-center gap-2">
        {/* previous */}
        {hasPrevPage ? (
          <a
            href={indexPageLink ? `/blog/` : `/blog/page/${currentPage - 1}/`}
            class="arrow active"
          >
            <span class="sr-only">Previous</span>
            <ChevronLeft />
          </a>
        ) : (
          <span class="arrow inactive">
            <span class="sr-only">Previous</span>
            <ChevronLeft />
          </span>
        )}

        {/* page index */}
        {pageList.map((pagination, index) =>
          pagination === '...' ? (
            <span class="index index-dots">{pagination}</span>
          ) : pagination === currentPage ? (
            <span aria-current="page" class="index index-current">
              {pagination}
            </span>
          ) : (
            <a
              href={pagination === 1 ? `/blog/` : `/blog/page/${pagination}/`}
              aria-current="page"
              class="index index-other"
            >
              {pagination}
            </a>
          )
        )}

        {/* next page */}
        {hasNextPage ? (
          <a href={`/blog/page/${currentPage + 1}/`} class="arrow active">
            <span class="sr-only">Next</span>
            <ChevronRight />
          </a>
        ) : (
          <span class="arrow inactive">
            <span class="sr-only">Next</span>
            <ChevronRight />
          </span>
        )}
      </nav>
    )
  }
</section>
