---
import HeaderLink from '@components/HeaderLink.astro';
import Search from '@components/icons/Search.astro';

import logoBadge from '@icons/logo-badge.svg';
import logoText from '@icons/logo-text.svg';
---

<header
  id="header"
  class="fixed top-0 left-0 z-[998] m-0 w-screen max-w-[calc(100vw-2em)] bg-[var(--translucent)] p-4 backdrop-blur-[10px] transition-transform duration-300 ease-in-out"
>
  <nav class="relative flex items-center justify-between">
    <div class="title ml-[10%] max-[720px]:ml-0 max-[720px]:scale-[0.8] max-lg:ml-4">
      <a
        data-expand
        href="/"
        aria-label="Return to Home"
        class="flex items-center gap-3.5 no-underline"
      >
        <img
          src={logoBadge.src}
          height="1.1rem"
          alt="logo-badge"
          aria-label="logo-badge"
          class="h-[1.1rem] rounded-none"
        />
        <img
          src={logoText.src}
          height="1.1rem"
          alt="logo-text"
          aria-label="Logo-text"
          class="h-[1.1rem] rounded-none max-[636px]:hidden"
        />
      </a>
    </div>
    <div class="absolute left-1/2 flex -translate-x-1/2 text-[0.9em]">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog/">Blog</HeaderLink>
      <HeaderLink href="/about/">About</HeaderLink>
    </div>
    <div
      class="icon-links mr-[10%] flex items-center max-[720px]:mr-0 max-[720px]:scale-[0.8] max-lg:mr-4"
    >
      <a
        data-expand
        href="/search/"
        aria-label="Search"
        class="flex items-center border-none text-[var(--gray-850)] no-underline hover:text-[var(--orange-neon)]"
      >
        <Search class="icon-search" />
      </a>
    </div>
  </nav>
</header>

<style>
  /* Icon hover animation — must remain in CSS */
  .icon-links a:hover {
    animation: scale-up-down 0.6s ease;
  }
  @keyframes scale-up-down {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.2);
    }
    100% {
      transform: scale(1);
    }
  }
</style>

<script>
  const header = document.getElementById('header');

  /* Hide or show the header when scrolling the page */
  let lastScrollTop = 0;
  let isTOCClick = false;

  // Listen for scroll events
  window.addEventListener('scroll', function () {
    const scrollTop = window.scrollY || document.documentElement.scrollTop;
    if (header && !isTOCClick) {
      if (scrollTop > lastScrollTop) {
        // Scrolling down
        header.style.transform = 'translateY(-100%)';
      } else {
        // Scrolling up
        header.style.transform = 'translateY(0)';
      }
    }
    lastScrollTop = scrollTop;
    isTOCClick = false; // Reset TOC click status
  });

  // Listen for click events on in-page links
  document.querySelectorAll('a[href*="#"]').forEach((link) => {
    if (header) {
      link.addEventListener('click', () => {
        isTOCClick = true;
        header.style.transform = 'translateY(-100%)';
      });
    }
  });
</script>
