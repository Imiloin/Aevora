---
import aboutConfig from '@configs/about.json';
import CCIcons from '@components/icons/CCIcons.astro';

const licenseUrl = 'https://creativecommons.org/licenses/by-nc-sa/4.0/';

interface Props {
  title: string;
  pageUrl?: string;
}
const { title, pageUrl } = Astro.props as Props;
const currentPageUrl = pageUrl ?? Astro.url?.href ?? '';
const hasPageUrl = Boolean(currentPageUrl);
---

<style>
  /* Container */
  .license-card {
    position: relative;
    margin: 2rem auto 0;
    padding: 1rem;
    border-radius: 8px;
    background-color: color-mix(in srgb, var(--gray-050) 80%, transparent);
    color: var(--gray-850);
    width: var(--width);
    max-width: calc(100% - 2rem);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .license-card__bg {
    position: absolute;
    right: -10px;
    top: -30px;
    width: 200px;
    height: 200px;
    opacity: 0.07;
    pointer-events: none;
  }

  .license-card__content {
    padding: 0 0.5rem;
  }

  .license-card__title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0.4rem 0;
  }

  .license-card__meta {
    display: flex;
    flex-wrap: wrap;
    column-gap: 0.75rem;
    row-gap: 0.4rem;
    font-size: 0.9rem;
    align-items: center;
    margin: 0.4rem 0;
  }

  .license-card__pair {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .license-card__label {
    color: var(--gray-600);
    white-space: nowrap;
  }

  .license-card__link {
    font-size: 0.9rem;
    margin: 0.4rem 0;
  }

  @media (max-width: 750px) {
    .license-card__bg {
      display: none;
    }
  }
</style>

<section class="license-card" aria-label="License information">
  <!-- Light watermark CC-like background -->
  <svg class="license-card__bg" viewBox="0 0 120 120" aria-hidden="true">
    <circle cx="60" cy="60" r="55" fill="none" stroke="currentColor" stroke-width="10"></circle>
    <text
      x="50%"
      y="54%"
      text-anchor="middle"
      dominant-baseline="middle"
      font-size="64"
      font-weight="700"
      style="user-select: none;"
    >
      CC
    </text>
  </svg>

  <div class="license-card__content">
    <p class="license-card__title">
      {title}
    </p>

    <p class="license-card__meta">
      <span class="license-card__pair">
        <span class="license-card__label">Author</span>
        <span class="license-card__value">{aboutConfig.basic.name}</span>
      </span>
      <span class="license-card__pair">
        <span class="license-card__label">License</span>
        <span class="license-card__value">
          <CCIcons />
          <a href={licenseUrl} target="_blank" rel="noopener noreferrer"> CC BY-NC-SA 4.0 </a>
        </span>
      </span>

      <p class="license-card__link">
        {
          hasPageUrl ? (
            <a href={currentPageUrl} target="_blank" rel="noopener noreferrer">
              {currentPageUrl}
            </a>
          ) : (
            <span class="license-card__value">Current page</span>
          )
        }
      </p>
    </p>
  </div>
</section>
