---
import CCLicense from '@components/icons/CCLicense.astro';
import aboutConfig from '@configs/about.json';

const licenseUrl = 'https://creativecommons.org/licenses/by-nc-sa/4.0/';

interface Props {
  title: string;
  pageUrl?: string;
}
const { title, pageUrl } = Astro.props as Props;
const currentPageUrl = pageUrl ?? Astro.url?.href ?? '';
const hasPageUrl = Boolean(currentPageUrl);
---

<style>
  .license-card__bg {
    position: absolute;
    right: -10px;
    top: -30px;
    opacity: 0.07;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .license-card__bg {
      display: none;
    }
  }

  /* LicenseCard link styling */
  section a {
    color: inherit;
    text-decoration: none;
    box-shadow: 0 -1px 0 currentColor inset;
    transition: color 0.2s ease;

    &:hover {
      color: var(--gray-700);
    }
  }
</style>

<section
  class="relative mx-auto mt-8 box-border flex w-(--width) max-w-[calc(100%-2em)] flex-col gap-[0.4rem] overflow-hidden rounded-lg bg-[color-mix(in_srgb,var(--gray-050)_80%,transparent)] p-4 text-(--gray-850)"
  aria-label="License information"
>
  <!-- Light watermark CC-like background -->
  <svg class="license-card__bg size-50" viewBox="0 0 120 120" aria-hidden="true">
    <circle cx="60" cy="60" r="55" fill="none" stroke="currentColor" stroke-width="10"></circle>
    <text
      x="50%"
      y="54%"
      text-anchor="middle"
      dominant-baseline="middle"
      font-size="64"
      font-weight="700"
      style="user-select: none;"
    >
      CC
    </text>
  </svg>

  <div class="px-2">
    <p class="my-[0.4rem] text-base font-semibold">
      {title}
    </p>

    <p class="my-[0.4rem] flex flex-wrap items-center gap-x-3 gap-y-[0.4rem] text-[0.9rem]">
      <span class="inline-flex items-center gap-[0.35rem]">
        <span class="whitespace-nowrap text-(--gray-600)">Author</span>
        <span>{aboutConfig.basic.name}</span>
      </span>
      <span class="inline-flex items-center gap-[0.35rem]">
        <span class="whitespace-nowrap text-(--gray-600)">License</span>
        <span>
          <CCLicense />
          <a href={licenseUrl} target="_blank" rel="noopener noreferrer"> CC BY-NC-SA 4.0 </a>
        </span>
      </span>

      <p class="my-[0.4rem] text-[0.9rem]">
        {
          hasPageUrl ? (
            <a href={currentPageUrl} target="_blank" rel="noopener noreferrer">
              {currentPageUrl}
            </a>
          ) : (
            <span>Current page</span>
          )
        }
      </p>
    </p>
  </div>
</section>
